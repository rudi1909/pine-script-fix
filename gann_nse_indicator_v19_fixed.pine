//@version=6
// ============================================================================
// GANN SIGNAL ENGINE [NSE] - v19 CLEAN
//
// TRADER OUTPUT: 3 things only
//   BUY  (green arrow up)   = Buy CALL option next bar
//   SELL (red arrow down)   = Buy PUT option next bar
//   EXIT (orange X)         = Close position
//
// Arrow SIZE shows conviction:
//   Large  = score >= 75 (strong signal, full size)
//   Normal = score 55-74 (normal signal, half size)
//
// INTERNALLY all theories run silently:
//   Gann Time B/A/C/D + Harmonics + Combinations
//   Range Position + Square of 9 + 1x1 Angle
//   EMA + ADX + RSI Divergence + VWAP
//   PA Patterns + OCB + ORB + Rule of 3
//   Trend Continuation + VWAP Cross
//
// TABLE: 4 rows - Next signal time, Direction, Score, Action
// PLOT SLOTS: 3 plot + 4 plotshape = 7 TOTAL
// ============================================================================
indicator("Gann Signal Engine [NSE]", overlay=true, max_lines_count=300, max_labels_count=300, max_bars_back=500)

// ── INPUTS ───────────────────────────────────────────────────────────────────
g1 = "Gann Price"
i_whole     = input.int(23110,      "Whole Price (e.g. 23110)",      group=g1, minval=1)
i_decimal   = input.float(23110.15, "Decimal Price (e.g. 23110.15)", group=g1, step=0.05)
i_auto_open = input.bool(false,     "Auto Open - Back Test Mode",    group=g1, tooltip="TRUE = each day uses real open. FALSE = manual for live trading.")

g2 = "Filters"
i_ema_fast  = input.int(9,    "Fast EMA",             group=g2, minval=2)
i_ema_slow  = input.int(21,   "Slow EMA",             group=g2, minval=5)
i_rsi_len   = input.int(14,   "RSI Length",           group=g2)
i_rsi_trap  = input.int(40,   "RSI Trap Level",       group=g2, minval=20, maxval=55)
i_min_score = input.int(55,   "Min Score (55-90)",    group=g2, minval=30, maxval=90, tooltip="Raise to 65-70 for fewer, cleaner signals.")
i_min_votes = input.int(4,    "Min Votes (3-8)",      group=g2, minval=2,  maxval=10, tooltip="How many theories must agree. Higher = fewer signals.")
i_sq9_step  = input.int(45,   "Sq9 Step pts",         group=g2, minval=10, maxval=100)
i_gann_tol  = input.float(0.5,"Gann Level Tol %",     group=g2, minval=0.1, maxval=2.0, step=0.1)
i_angle_fac = input.float(7.0,"1x1 Angle pts/bar",    group=g2, minval=1.0, maxval=30.0, step=0.5)
i_div_len   = input.int(5,    "Divergence Lookback",  group=g2, minval=3,  maxval=15)

g4 = "SMC - FVG and Liquidity"
i_fvg_min    = input.int(15,    "FVG Min Size (pts)",       group=g4, minval=5, maxval=50,  tooltip="Minimum gap size to count as FVG. Filters tiny gaps.")
i_lsw_bars   = input.int(10,    "Sweep Lookback Bars",      group=g4, minval=5, maxval=20,  tooltip="Bars to look back for swing high/low detection.")
i_ai_noise   = input.bool(true,  "AI Noise Filter",         group=g4, tooltip="Blocks harmonic signals when same-direction primary already fired today.")
i_extra_sigs = input.bool(false, "Extra Signals (ORB/VWAP/PA/EMA)", group=g4, tooltip="OFF = only Gann bars fire (cleanest). ON = also ORB, VWAP cross, EMA cross, PA signals.")
i_show_fvg   = input.bool(false, "Show FVG Zones",          group=g4, tooltip="Plot Fair Value Gap zones on chart - off by default")

g3 = "Display"
i_show_ema   = input.bool(true,  "Show EMA Lines",           group=g3)
i_show_sl    = input.bool(true,  "Show Stop Loss Line",      group=g3)
i_show_vwap  = input.bool(true,  "Show VWAP",                group=g3)
i_show_table = input.bool(true,  "Show Info Table",          group=g3)
i_show_bg    = input.bool(true,  "Colour Signal Bars",       group=g3)
i_show_cd    = input.bool(true,  "Show C/D Time Lines",      group=g3, tooltip="Gold dashed lines at C and D bar times")
i_show_harm  = input.bool(false, "Show Harmonic Lines",      group=g3, tooltip="Orange lines at harmonic bars - off by default")
i_show_orb   = input.bool(false, "Show ORB Lines",           group=g3, tooltip="Opening Range Breakout high/low lines - off by default")
i_show_g50   = input.bool(false, "Show Gann 50% Level",      group=g3, tooltip="Gann midpoint circles - off by default")
i_tbl_pos    = input.string("Bottom Right","Table Position", options=["Bottom Right","Bottom Left","Top Right","Top Left"], group=g3)

g5 = "Back Test"
i_historical = input.bool(false, "Show Historical Signals", group=g5)
i_hist_days  = input.int(30,    "Days Back",                group=g5, minval=1, maxval=365)

// ── COLORS ───────────────────────────────────────────────────────────────────
color C_EMA9  = #27AE60
color C_EMA21 = #C0392B
color C_SL    = #E74C3C
color C_VWAP  = #FF9800
color C_BUY   = #27AE60
color C_SELL  = #C0392B
color C_FVG_B = color.new(#27AE60, 70)
color C_FVG_S = color.new(#C0392B, 70)
color C_EXIT  = #F39C12
color C_BGBUY = color.new(#27AE60, 88)
color C_BGSEL = color.new(#C0392B, 88)
color C_G50   = #C9A84C

// ── HELPERS ──────────────────────────────────────────────────────────────────
digitSum(int n) =>
    int dx = math.abs(n)
    int ds = 0
    ds := ds + dx % 10
    dx := int(math.floor(float(dx) / 10.0))
    ds := ds + dx % 10
    dx := int(math.floor(float(dx) / 10.0))
    ds := ds + dx % 10
    dx := int(math.floor(float(dx) / 10.0))
    ds := ds + dx % 10
    dx := int(math.floor(float(dx) / 10.0))
    ds := ds + dx % 10
    dx := int(math.floor(float(dx) / 10.0))
    ds := ds + dx % 10
    int(ds)

digitalRoot(int n) =>
    int dr = int(n) % 9
    dr == 0 ? (n == 0 ? 0 : 9) : int(dr)

toHHMM(int mins) =>
    int tt = 555 + int(math.max(float(mins), 0.0))
    int th = int(math.floor(float(tt)/60.0))
    int tr = tt - th*60
    int tm = int(math.floor(float(tr)/5.0))*5
    th*100 + tm

fmtT(int hhmm) =>
    int fh = int(math.floor(float(hhmm)/100.0))
    int fm = hhmm - fh*100
    int h12 = fh > 12 ? fh-12 : (fh == 0 ? 12 : fh)
    str.tostring(h12) + ":" + (fm < 10 ? "0" : "") + str.tostring(fm) + (fh >= 12 ? "PM" : "AM")

inSess(int hhmm) =>
    int h = hhmm / 100
    int m = hhmm - h * 100
    int t = h * 60 + m
    t >= 555 and t <= 915

// ── AUTO OPEN ────────────────────────────────────────────────────────────────
float _dOpen   = request.security(syminfo.tickerid, "D", open, lookahead=barmerge.lookahead_off)
int   _useW    = i_auto_open and not na(_dOpen) ? int(math.floor(_dOpen)) : i_whole
int   _useD    = i_auto_open and not na(_dOpen) ? int(math.round((_dOpen - math.floor(_dOpen))*100)) : int(math.round((i_decimal - math.floor(i_decimal))*100))

// ── GANN TIME ────────────────────────────────────────────────────────────────
int v1  = digitSum(_useW)
int v2  = v1 + digitSum(_useD)
int dr2 = digitalRoot(v2)
int fB  = 2*v1-dr2
int fA  = v1+v2-dr2
int fC  = (v2-v1)*15
int fD  = v1*9+(v2-v1-dr2)
// Harmonics
int fD2 = fD * 2
int fD3 = fD * 3
int fD4 = fD * 4
int fD5 = fD * 5
int fC2 = fC * 2
int fC3 = fC * 3
int fC4 = fC * 4
// Combinations
int fCb1 = fC2 + fB           // C2+B  = fills 12:15-12:30 gap
int fCb2 = fD3 + fA           // D3+A  = fills gaps
int fCb3 = fC2 + fD           // C2+D  = 1:20 PM area
int fCb4 = fC3 - fD           // C3-D  = fills gap
int fCb5 = fD4 + fA           // D4+A  = afternoon
int fCb6 = fC3 + fB           // C3+B  = afternoon
// NEW combos to fill 12:45-1:20 PM blind spot
int fCb7 = fD2 + fC            // D2+C  = 12:55 PM fills gap
int fCb8 = fC2 + fD - fB       // C2+D-B = 1:10 PM fills gap

int tB  = toHHMM(fB)
int tA  = toHHMM(fA)
int tC  = toHHMM(fC)
int tD  = toHHMM(fD)
int tD2 = toHHMM(fD2)
int tD3 = toHHMM(fD3)
int tD4 = toHHMM(fD4)
int tD5 = toHHMM(fD5)
int tC2 = toHHMM(fC2)
int tC3 = toHHMM(fC3)
int tC4 = toHHMM(fC4)
int tCb1 = fCb1 > 0 ? toHHMM(fCb1) : 0
int tCb2 = fCb2 > 0 ? toHHMM(fCb2) : 0
int tCb3 = fCb3 > 0 ? toHHMM(fCb3) : 0
int tCb4 = fCb4 > 0 ? toHHMM(fCb4) : 0
int tCb5 = fCb5 > 0 ? toHHMM(fCb5) : 0
int tCb6 = fCb6 > 0 ? toHHMM(fCb6) : 0

// ── SESSION ───────────────────────────────────────────────────────────────────
var float _cutT = float(na)
var float _cutH = float(na)
if barstate.isfirst
    _cutT := float(timenow) - 86400000.0
    _cutH := float(timenow) - float(i_hist_days)*86400000.0

bool isToday  = float(time) >= _cutT
bool isHist   = i_historical and float(time) >= _cutH and float(time) < _cutT
bool isActive = isToday or isHist
bool inSess2  = (hour>9 or (hour==9 and minute>=15)) and (hour<15 or (hour==15 and minute<=30))
bool liveBar  = isActive and inSess2
int  bHHMM    = hour*100 + int(math.floor(float(minute)/5.0))*5

// ── SIGNAL BAR FLAGS ─────────────────────────────────────────────────────────
bool atB=liveBar and bHHMM==tB
bool atA=liveBar and bHHMM==tA
bool atC=liveBar and fC>0 and bHHMM==tC
bool atD=liveBar and bHHMM==tD
bool atD2=liveBar and fD>0 and bHHMM==tD2 and inSess(tD2)
bool atD3=liveBar and fD>0 and bHHMM==tD3 and inSess(tD3)
bool atD4=liveBar and fD>0 and bHHMM==tD4 and inSess(tD4)
bool atD5=liveBar and fD>0 and bHHMM==tD5 and inSess(tD5)
bool atC2=liveBar and fC>0 and bHHMM==tC2 and inSess(tC2)
bool atC3=liveBar and fC>0 and bHHMM==tC3 and inSess(tC3)
bool atC4=liveBar and fC>0 and bHHMM==tC4 and inSess(tC4)
bool atCb1=liveBar and fCb1>0 and bHHMM==tCb1 and inSess(tCb1)
bool atCb2=liveBar and fCb2>0 and bHHMM==tCb2 and inSess(tCb2)
bool atCb3=liveBar and fCb3>0 and bHHMM==tCb3 and inSess(tCb3)
bool atCb4=liveBar and fCb4>0 and bHHMM==tCb4 and inSess(tCb4)
bool atCb5=liveBar and fCb5>0 and bHHMM==tCb5 and inSess(tCb5)
bool atCb6=liveBar and fCb6>0 and bHHMM==tCb6 and inSess(tCb6)
bool atAny  = atB or atA or atC or atD
bool atCharm = atC2 or atC3 or atC4
bool atDharm = atD2 or atD3 or atD4
bool atCombo = atCb1 or atCb2 or atCb3 or atCb4 or atCb5 or atCb6
bool atHarm = atCharm or atDharm or atCombo
bool atGann = atAny or atHarm

// ── INDICATORS ───────────────────────────────────────────────────────────────
float rsi      = ta.rsi(close, i_rsi_len)
float emaFast  = ta.ema(close, i_ema_fast)
float emaSlow  = ta.ema(close, i_ema_slow)
float vwapVal  = ta.vwap(hlc3)
bool  emaUp    = emaFast > emaSlow
bool  bull     = close > open
bool  bear     = close < open
bool  doji     = (high>low) ? math.abs(close-open)/(high-low) < 0.1 : false
float lw       = high>low ? (math.min(open,close)-low)/(high-low) : 0.0
float uw       = high>low ? (high-math.max(open,close))/(high-low) : 0.0
float bd       = high>low ? math.abs(close-open)/(high-low) : 0.0

// ── ADX ──────────────────────────────────────────────────────────────────────
float dmP  = math.max(high-high[1], 0.0)
float dmM  = math.max(low[1]-low,   0.0)
float trR  = math.max(high-low, math.max(math.abs(high-close[1]), math.abs(low-close[1])))
float a14  = ta.rma(trR, 14)
float diP  = ta.rma(dmP>dmM?dmP:0.0, 14)/a14*100
float diM  = ta.rma(dmM>dmP?dmM:0.0, 14)/a14*100
float adx  = ta.rma(math.abs(diP-diM)/(diP+diM)*100, 14)
bool adxOK     = adx >= 20.0
bool adxStrong = adx >= 40.0
bool emaActive = math.abs(emaFast - emaFast[5]) >= 3.0

// ── DAY TRACKING ─────────────────────────────────────────────────────────────
var float dayOpen = float(na)
var float dayHigh = float(na)
var float dayLow  = float(na)
var int   dayBars = 0
var int   dayNum  = 0

if isActive and hour == 9 and minute == 15 and dayofmonth != dayNum
    dayOpen := open
    dayHigh := high
    dayLow  := low
    dayBars := 0
    dayNum  := dayofmonth

if isActive and inSess2 and barstate.isconfirmed
    dayHigh := na(dayHigh) ? high : math.max(dayHigh,high)
    dayLow  := na(dayLow)  ? low  : math.min(dayLow, low)
    dayBars := dayBars+1

float dayRange = na(dayHigh) or na(dayLow) ? float(na) : dayHigh-dayLow

// ── GANN PRICE ───────────────────────────────────────────────────────────────
float g50 = na(dayLow) or na(dayRange) ? float(na) : dayLow+dayRange*0.5
float g25 = na(dayLow) or na(dayRange) ? float(na) : dayLow+dayRange*0.25
float g75 = na(dayLow) or na(dayRange) ? float(na) : dayLow+dayRange*0.75
gNear(float lv) => not na(lv) ? math.abs(close-lv)/close*100 <= i_gann_tol : false
bool atG50 = gNear(g50)
bool atG25 = gNear(g25)
bool atG75 = gNear(g75)

// Square of 9
bool atSq9 = not na(dayOpen) and (gNear(dayOpen+float(i_sq9_step)) or gNear(dayOpen+float(i_sq9_step)*2.0) or gNear(dayOpen+float(i_sq9_step)*3.0) or gNear(dayOpen+float(i_sq9_step)*4.0) or gNear(dayOpen+float(i_sq9_step)*5.0) or gNear(dayOpen-float(i_sq9_step)) or gNear(dayOpen-float(i_sq9_step)*2.0) or gNear(dayOpen-float(i_sq9_step)*3.0) or gNear(dayOpen-float(i_sq9_step)*4.0) or gNear(dayOpen-float(i_sq9_step)*5.0))

// 1x1 Angle
float ang  = not na(dayOpen) ? dayOpen+float(dayBars)*i_angle_fac : float(na)
float angB = not na(dayOpen) ? dayOpen-float(dayBars)*i_angle_fac : float(na)
bool abvAng = not na(ang)  and close > ang
bool blwAng = not na(angB) and close < angB

// Range position
float rangePct = na(dayHigh) or na(dayLow) or na(dayRange) or dayRange<5.0 ? 0.5 : (close-dayLow)/dayRange
bool nearHigh = rangePct > 0.80
bool nearLow  = rangePct < 0.20
float moveSinceLow  = na(dayLow)  ? 0.0 : close-dayLow
float moveSinceHigh = na(dayHigh) ? 0.0 : dayHigh-close
bool bigRally  = moveSinceLow  > 150.0 and nearHigh
bool bigCrash  = moveSinceHigh > 150.0 and nearLow

// ── OPENING SIGNALS ───────────────────────────────────────────────────────────
var int openBias = 0
var int ocbDay   = 0
if isActive and hour == 9 and minute == 15 and dayofmonth != ocbDay and barstate.isconfirmed
    openBias := close < open ? -1 : close > open ? 1 : 0
    ocbDay   := dayofmonth

var float orbH    = float(na)
var float orbL    = float(na)
var int   orbN    = 0
var bool  orbDone = false
var int   orbDay  = 0
if isActive and hour == 9 and minute == 15 and dayofmonth != orbDay
    orbH    := float(na)
    orbL    := float(na)
    orbN    := 0
    orbDone := false
    orbDay  := dayofmonth
if isActive and inSess2 and not orbDone and barstate.isconfirmed
    if orbN < 3
        orbH := na(orbH) ? high : math.max(orbH,high)
        orbL := na(orbL) ? low  : math.min(orbL, low)
        orbN := orbN+1
    else
        orbDone := true

bool ocbBuy  = liveBar and hour==9 and minute==20 and openBias==1  and bull and not doji and barstate.isconfirmed
bool ocbSell = liveBar and hour==9 and minute==20 and openBias==-1 and bear and not doji and barstate.isconfirmed
bool orbBuy  = orbDone and not na(orbH) and close[1]>orbH and bull[1] and barstate.isconfirmed and liveBar
bool orbSell = orbDone and not na(orbL) and close[1]<orbL and bear[1] and barstate.isconfirmed and liveBar

// ── PA PATTERNS ───────────────────────────────────────────────────────────────
bool hamr = lw>0.6 and bd<0.3
bool sstr = uw>0.6 and bd<0.3
bool bEng = bull and close>open[1] and open<close[1]
bool rEng = bear and close<open[1] and open>close[1]

// ── GANN RULE OF 3 ────────────────────────────────────────────────────────────
bool bear3 = bear[1] and bear[2] and bear[3]
bool bull3 = bull[1] and bull[2] and bull[3]
bool r3Buy  = bear3 and bull and not doji and liveBar
bool r3Sell = bull3 and bear and not doji and liveBar

// ── RSI DIVERGENCE ────────────────────────────────────────────────────────────
bool bearDivS = liveBar and high[1]>high[i_div_len+1]  and rsi[1]<rsi[i_div_len+1]  and not na(rsi[i_div_len+1])
bool bullDivS = liveBar and low[1] <low[i_div_len+1]   and rsi[1]>rsi[i_div_len+1]  and not na(rsi[i_div_len+1])
bool bearDivL = liveBar and high[1]>high[11]            and rsi[1]<rsi[11]            and not na(rsi[11])
bool bullDivL = liveBar and low[1] <low[11]             and rsi[1]>rsi[11]            and not na(rsi[11])
bool bearDiv = bearDivS or bearDivL
bool bullDiv = bullDivS or bullDivL

// ── EXHAUSTION ────────────────────────────────────────────────────────────────
bool postCrashBuy  = nearLow  and rsi < 35.0 and bull and not doji and liveBar
bool postRallyPUT  = nearHigh and rsi > 65.0 and bear and not doji and liveBar
float b0 = math.abs(close - open)
float b1 = math.abs(close[1] - open[1])
float b2 = math.abs(close[2] - open[2])
bool bullExh = bull and bull[1] and bull[2] and b0<b1 and b1<b2
bool bearExh = bear and bear[1] and bear[2] and b0<b1 and b1<b2

// ── VWAP ──────────────────────────────────────────────────────────────────────
bool abvVWAP = not na(vwapVal) and close > vwapVal
bool blwVWAP = not na(vwapVal) and close < vwapVal
bool vwapPUT = liveBar and not na(vwapVal) and close<vwapVal and close[1]>=vwapVal[1] and not emaUp and not doji and barstate.isconfirmed
bool vwapBUY = liveBar and not na(vwapVal) and close>vwapVal and close[1]<=vwapVal[1] and emaUp      and not doji and barstate.isconfirmed

// ── PA-ONLY BLIND SPOT ────────────────────────────────────────────────────────
bool paOnlyBUY  = liveBar and not atGann and adxOK and bullDiv and (hamr or bEng) and not doji and barstate.isconfirmed
bool paOnlySELL = liveBar and not atGann and adxOK and bearDiv and (sstr or rEng) and not doji and barstate.isconfirmed

// ── EMA CROSSOVER — catches mid-session reversals in Gann blind spots ────────
// EMA9 crosses ABOVE EMA21 = trend flipped bullish = BUY (no Gann bar needed)
// EMA9 crosses BELOW EMA21 = trend flipped bearish = SELL
// Must have: ADX trending + not at range extreme + confirmed bar
bool emaCrossBUY  = liveBar and emaUp and not emaUp[1] and adxOK and not nearHigh and not doji and barstate.isconfirmed
bool emaCrossSELL = liveBar and not emaUp and emaUp[1]  and adxOK and not nearLow  and not doji and barstate.isconfirmed

// ── TREND CONTINUATION ────────────────────────────────────────────────────────
float atr5 = ta.atr(5)
bool bigBull = bull and not doji and math.abs(close-open) > atr5*0.5
bool bigBear = bear and not doji and math.abs(close-open) > atr5*0.5
bool contBUY  = liveBar and emaUp     and not atGann and bigBull and rsi > 45 and not nearHigh and barstate.isconfirmed
bool contSELL = liveBar and not emaUp and not atGann and bigBear and rsi < 55 and not nearLow  and barstate.isconfirmed

// ══════════════════════════════════════════════════════════════════════════════
// VOTE ENGINE — all theories cast directional votes
// ══════════════════════════════════════════════════════════════════════════════

// BIG BOUNCE DETECTION
bool bigBounceUp   = moveSinceLow > 150.0
bool bigBounceDown = moveSinceHigh > 150.0

// FREEFALL GUARD: near day low but EMA still bear, RSI not oversold = still falling
// Suppress BUY-biased votes to prevent false BUY at bottom of crash
bool freefallLow  = nearLow  and not emaUp and rsi > 32 and math.abs(close - open) <= 15
bool freefallHigh = nearHigh and emaUp      and rsi < 68 and math.abs(close - open) <= 15

int vVWAP_raw = abvVWAP ? 1 : blwVWAP ? -1 : 0
int vVWAP  = (bigBounceUp and atGann) ? 0 : (bigBounceDown and atGann) ? 0 : vVWAP_raw
int vOCB_raw = openBias==1 ? 1 : openBias==-1 ? -1 : 0
int vOCB   = (bigBounceUp and not emaUp and atGann) ? 0 : freefallLow ? 0 : vOCB_raw
int vCdl_raw = bull and not doji ? 1 : bear and not doji ? -1 : 0
int vCdl   = (bigBounceUp and atGann and not emaUp) ? -1 : (bigBounceDown and atGann and emaUp) ? 1 : freefallLow ? 0 : vCdl_raw

int vEMA   = emaUp ? 2 : -2
int vDiv   = bullDiv ? 2 : bearDiv ? -2 : 0
int vAng   = abvAng ? 1 : blwAng ? -1 : 0
int vR3    = r3Buy ? 2 : r3Sell ? -2 : 0
int vPA    = (hamr or bEng) ? 2 : (sstr or rEng) ? -2 : 0
int vORB   = orbBuy ? 2 : orbSell ? -2 : 0
int vExh   = bullExh ? -1 : bearExh ? 1 : 0
bool nearLowBuy   = nearLow  and (rsi < 30 or (bull and math.abs(close - open) > 15))
bool nearHighSell = nearHigh and (rsi > 70 or (bear and math.abs(close - open) > 15))
int vRng   = nearHighSell ? -3 : nearLowBuy ? 3 : 0
// vMov: bigCrash only votes BUY if RSI extreme oversold (not just proximity to low)
int vMov   = bigRally ? -3 : (bigCrash and rsi < 32) ? 3 : 0
// vEMAdj: near_low boost only when RSI confirms extreme oversold
int vEMAdj = (nearHigh and emaUp) ? -2 : (nearLow and not emaUp and rsi < 32) ? 2 : 0
int vRSI   = postCrashBuy ? 3 : postRallyPUT ? -3 : 0

// ── THEORY 15: FAIR VALUE GAP (FVG) ─────────────────────────────────────────
// 3-candle imbalance: gap between candle[2] and candle[0] = price likely returns
// Only count gaps larger than i_fvg_min pts to filter micro-noise
float fvgBullGap = low[2] - high[0]   // bullish FVG: candle[2] low above candle[0] high
float fvgBearGap = low[0] - high[2]   // bearish FVG: candle[0] low above candle[2] high
bool  bullFVG    = fvgBullGap > i_fvg_min and liveBar
bool  bearFVG    = fvgBearGap > i_fvg_min and liveBar
// Price inside FVG zone = high probability fill area
bool inBullFVG = bullFVG[1] and close >= high[1] and close <= low[3]
bool inBearFVG = bearFVG[1] and close <= low[1]  and close >= high[3]
int  vFVG = inBullFVG ? 2 : inBearFVG ? -2 : 0

// ── THEORY 16: LIQUIDITY SWEEP (LSW) ────────────────────────────────────────
// Stop hunt: price spikes beyond swing extreme then closes back inside
// = smart money grabbed retail stops = reversal signal
float swingHi = ta.highest(high, i_lsw_bars)[1]   // previous swing high
float swingLo = ta.lowest(low,   i_lsw_bars)[1]   // previous swing low
// Bullish sweep: wick below swing low, closes back above = lows swept, bounce
bool bullSweep = low < swingLo and close > swingLo and liveBar and adxOK
// Bearish sweep: wick above swing high, closes back below = highs swept, drop
bool bearSweep = high > swingHi and close < swingHi and liveBar and adxOK
int  vLSW = bullSweep ? 3 : bearSweep ? -3 : 0

int totalV = int(vEMA+vDiv+vOCB+vVWAP+vAng+vR3+vPA+vORB+vCdl+vExh+vRng+vMov+vEMAdj+vRSI+vFVG+vLSW)
bool buyDir  = totalV > 0
bool sellDir = totalV < 0
int  absV    = int(math.abs(float(totalV)))

// ── CONFIDENCE SCORE ─────────────────────────────────────────────────────────
// Raised harmonic score from 8 → 15 (was too low, preventing 1:35 PM D×4 signals)
// Added bounce exhaustion: big bounce from day low at harmonic = high SELL probability
int sc_time = atC or atD ? 20 : atA or atB ? 12 : atHarm ? 15 : 0
int sc_g50  = atG50 ? 20 : 0
int sc_g25  = atG25 or atG75 ? 12 : 0
int sc_sq9  = atSq9 ? 12 : 0
int sc_ang  = ((abvAng and buyDir) or (blwAng and sellDir)) ? 12 : 0
int sc_adx  = adxStrong ? 10 : adxOK ? 5 : -15
int sc_pa   = (hamr or bEng or sstr or rEng) ? 12 : 0
int sc_div  = ((bullDiv and buyDir) or (bearDiv and sellDir)) ? 15 : 0
int sc_vw   = ((abvVWAP and buyDir) or (blwVWAP and sellDir)) ? 8 : 0
int sc_r3   = ((r3Buy and buyDir) or (r3Sell and sellDir)) ? 8 : 0
int sc_vote = absV>=8 ? 10 : absV>=6 ? 7 : absV>=4 ? 4 : absV>=3 ? 2 : 0
int sc_rng  = ((nearHighSell and sellDir) or (nearLowBuy and buyDir)) ? 15 : 0
int sc_exh  = ((bigRally and sellDir) or (bigCrash and buyDir)) ? 12 : 0
// Bounce exhaustion at harmonic: uses moveSinceLow/High already declared above
bool bounceAtHarm = atHarm and moveSinceLow > 150.0 and sellDir
bool crashAtHarm  = atHarm and moveSinceHigh > 150.0 and buyDir
int sc_bounce = (bounceAtHarm or crashAtHarm) ? 15 : 0
// FVG score: price inside imbalance zone at Gann bar = high conviction
int sc_fvg  = ((inBullFVG and buyDir) or (inBearFVG and sellDir)) ? 15 : 0
// LSW score: liquidity sweep confirms direction = very high conviction
int sc_lsw  = ((bullSweep and buyDir) or (bearSweep and sellDir)) ? 15 : 0
int score   = int(math.max(0.0, math.min(100.0, float(sc_time+sc_g50+sc_g25+sc_sq9+sc_ang+sc_adx+sc_pa+sc_div+sc_vw+sc_r3+sc_vote+sc_rng+sc_exh+sc_bounce+sc_fvg+sc_lsw)))

// ── SIDEWAYS DETECTION ────────────────────────────────────────────────────────
// Sideways = ADX weak + narrow day range + flat EMA
bool daySideways = adx < 20.0
bool dayWeak     = adx >= 20.0 and adx < 25.0
bool dayTrending = adx >= 25.0

// ORB width check — narrow opening range = sideways warning
float orbWidth = orbDone and not na(orbH) and not na(orbL) ? orbH - orbL : float(na)
bool orbNarrow = not na(orbWidth) and orbWidth < 30.0

// ── GATE — all conditions must pass ──────────────────────────────────────────
bool gGann  = atGann
bool gAdx   = adxOK
bool gDoji  = not doji
bool gVotes = absV >= i_min_votes
// Harmonic bars already penalised by lower sc_time — use slightly lower threshold
int  minScoreGate = atHarm ? int(math.max(float(i_min_score - 8), 38.0)) : i_min_score
bool gScore = score >= minScoreGate
bool gTrap  = not (bull and emaUp and rsi < i_rsi_trap)
// COUNTER-TREND FILTER:
// Block BUY signals on strong bear days (BEAR EMA + BearO + ADX>35 + RSI<32)
// unless at primary C or D bar (Gann primary = high conviction override)
// This prevents false CALL entries on crash days when RSI bounces
bool strongBearDay = not emaUp and openBias == -1 and adx > 35
bool strongBullDay = emaUp     and openBias ==  1 and adx > 35
bool gCTF = strongBearDay ? (buyDir  ? (atC or atD) : true) :
            strongBullDay ? (sellDir ? (atC or atD) : true) : true

// ── AI NOISE FILTER ──────────────────────────────────────────────────────────
// Tracks whether a primary C or D signal already fired today in each direction
// If primary already fired BUY → block harmonic BUY (noise suppression)
// Opposite direction always allowed (reversal signal)
var bool primaryBuyFired  = false
var bool primarySellFired = false
// Reset at start of each new day
bool newDay = not na(ta.change(time("D"))) and ta.change(time("D")) != 0
if newDay
    primaryBuyFired  := false
    primarySellFired := false
// Record when primary fires
bool isPrimary = atC or atD
if isPrimary and buyDir  and adxOK and not doji and barstate.isconfirmed
    primaryBuyFired  := true
if isPrimary and sellDir and adxOK and not doji and barstate.isconfirmed
    primarySellFired := true
// AI gate: if noise filter ON + harmonic bar + same-direction primary already fired = block
bool gAI = not i_ai_noise or not atHarm or (buyDir and not primaryBuyFired) or (sellDir and not primarySellFired)

bool gate   = gGann and gAdx and gDoji and gVotes and gScore and gTrap and gAI and gCTF

// ══════════════════════════════════════════════════════════════════════════════
// FINAL SIGNAL — with sideways suppression
// ══════════════════════════════════════════════════════════════════════════════
bool gannBUY  = gate and buyDir  and barstate.isconfirmed
bool gannSELL = gate and sellDir and barstate.isconfirmed

// High conviction override — score >= 75 at C or D bar can trade even on weak day
bool highConvBUY  = gannBUY  and score >= 75 and (atC or atD)
bool highConvSELL = gannSELL and score >= 75 and (atC or atD)

// Non-Gann signals — controlled by i_extra_sigs toggle (OFF by default = clean chart)
// Also: never fire extraBUY if gannSELL fires same bar, and vice versa
// Also: blocked on strong counter-trend days (extraBUY blocked on strong bear days)
bool extraBUY  = i_extra_sigs and not gannSELL and not strongBearDay and (
                 daySideways ? (orbBuy and barstate.isconfirmed) :
                 dayWeak     ? ((paOnlyBUY or vwapBUY or ocbBuy or orbBuy or emaCrossBUY) and absV >= i_min_votes + 2 and adxOK) :
                               ((paOnlyBUY or vwapBUY or ocbBuy or orbBuy or emaCrossBUY) and absV >= i_min_votes and adxOK))

bool extraSELL = i_extra_sigs and not gannBUY and not strongBullDay and (
                 daySideways ? (orbSell and barstate.isconfirmed) :
                 dayWeak     ? ((paOnlySELL or vwapPUT or ocbSell or orbSell or emaCrossSELL) and absV >= i_min_votes + 2 and adxOK) :
                               ((paOnlySELL or vwapPUT or ocbSell or orbSell or emaCrossSELL) and absV >= i_min_votes and adxOK))

bool sigBUY  = gannBUY  or extraBUY
bool sigSELL = gannSELL or extraSELL

// Strong = Gann bar + high score
bool strongBUY  = gannBUY  and score >= 75
bool strongSELL = gannSELL and score >= 75

// ── STOP LOSS TRACKER ────────────────────────────────────────────────────────
var float slLevel  = float(na)
var float entPrice = float(na)
var bool  inTrade   = false
var bool  isLong    = false
var bool  exitFired = false
var int   holdBars  = 0   // bars held since entry

// ATR for SL buffer — wider SL = fewer stop hunts
float atrSL   = ta.atr(14)
float slBuf   = adxStrong ? atrSL * 1.5 : adxOK ? atrSL * 1.0 : atrSL * 0.5

if sigBUY
    // SL = signal bar LOW minus ATR buffer (gives breathing room)
    slLevel   := low - slBuf
    entPrice  := close
    inTrade   := true
    isLong    := true
    exitFired := false
    holdBars  := 0

if sigSELL
    // SL = signal bar HIGH plus ATR buffer (gives breathing room above)
    slLevel   := high + slBuf
    entPrice  := close
    inTrade   := true
    isLong    := false
    exitFired := false
    holdBars  := 0

// Count bars held in trade
if inTrade and barstate.isconfirmed
    holdBars := holdBars + 1

// Profit tracking
float cP = inTrade and isLong     and not na(entPrice) ? close - entPrice : 0.0
float pP = inTrade and not isLong and not na(entPrice) ? entPrice - close : 0.0

// SMART TRAIL: only trail after minimum 3 bars (15 min) AND 30+ pts profit
// This prevents stop-hunt exits on first bounce candle
bool canTrail = holdBars >= 3
if inTrade and isLong     and not na(slLevel) and cP > 30 and canTrail
    slLevel := math.max(slLevel, close - cP * 0.5)
if inTrade and not isLong and not na(slLevel) and pP > 30 and canTrail
    slLevel := math.min(slLevel, close + pP * 0.5)

// SL hit — only check after minimum hold period (3 bars)
// In first 3 bars, only exit on extreme SL breach (2×ATR beyond signal bar)
bool hardSL  = inTrade and not exitFired and ((isLong and low  <= slLevel) or (not isLong and high >= slLevel))
bool slHit   = hardSL

// EXIT label: CALL or PUT
bool exitCallSignal = slHit and isLong
bool exitPutSignal  = slHit and not isLong

// Show EXIT only when no opposite signal fires on same bar
bool showExitCall = exitCallSignal and not sigSELL and barstate.isconfirmed
bool showExitPut  = exitPutSignal  and not sigBUY  and barstate.isconfirmed

if slHit
    inTrade   := false
    exitFired := true

// When opposite signal fires = auto-exit + reverse (SELL marker handles it)
// No EXIT marker needed — the new SELL/BUY arrow IS the exit signal

// ── PLOTS ────────────────────────────────────────────────────────────────────
plot(i_show_ema  ? emaFast : na, "EMA 9",  C_EMA9,  linewidth=1)
plot(i_show_ema  ? emaSlow : na, "EMA 21", C_EMA21, linewidth=2)
plot(i_show_sl and inTrade ? slLevel : na, "SL", C_SL, style=plot.style_linebr, linewidth=2)
plot(i_show_vwap ? vwapVal : na, "VWAP",  C_VWAP,  linewidth=1, style=plot.style_stepline)
plot(i_show_g50 and not na(g50) ? g50 : float(na), "G50%", C_G50, style=plot.style_circles, linewidth=1)
// ORB levels — off by default to keep chart clean
color C_ORB_L = #5BA8D4
plot(i_show_orb and orbDone and not na(orbH) ? orbH : float(na), "ORB High", C_ORB_L, linewidth=1, style=plot.style_stepline)
plot(i_show_orb and orbDone and not na(orbL) ? orbL : float(na), "ORB Low",  C_ORB_L, linewidth=1, style=plot.style_stepline)
// FVG zones — off by default
plot(i_show_fvg and bullFVG ? low[2]  : float(na), "Bull FVG Top", C_FVG_B, linewidth=1, style=plot.style_stepline)
plot(i_show_fvg and bearFVG ? high[2] : float(na), "Bear FVG Bot", C_FVG_S, linewidth=1, style=plot.style_stepline)

// ╔══════════════════════════════════════════════════════════════════╗
// ║  CHART SIGNALS — clean 3-level system                            ║
// ║  STR BUY/SELL = primary C/D score>=75  large arrow               ║
// ║  BUY/SELL     = primary C/D            normal arrow              ║
// ║  H BUY/SELL   = harmonic/combo         small arrow               ║
// ╚══════════════════════════════════════════════════════════════════╝

bool harmSELL = gannSELL and atHarm and not (atC or atD) and not strongSELL
bool harmBUY  = gannBUY  and atHarm and not (atC or atD) and not strongBUY

plotshape(strongBUY,                                   "STRONG BUY",  shape.arrowup,   location.belowbar, C_BUY,   size=size.large,  text="STR BUY")
plotshape(strongSELL,                                  "STRONG SELL", shape.arrowdown, location.abovebar, C_SELL,  size=size.large,  text="STR SELL")
plotshape(sigBUY  and not strongBUY  and not harmBUY,  "BUY",         shape.arrowup,   location.belowbar, #5DAE8B, size=size.normal, text="BUY")
plotshape(sigSELL and not strongSELL and not harmSELL, "SELL",        shape.arrowdown, location.abovebar, #C0605A, size=size.normal, text="SELL")
plotshape(harmBUY,                                     "H BUY",       shape.arrowup,   location.belowbar, #5DAE8B, size=size.small,  text="H BUY")
plotshape(harmSELL,                                    "H SELL",      shape.arrowdown, location.abovebar, #C0605A, size=size.small,  text="H SELL")
plotshape(showExitCall, "EXIT CALL", shape.xcross, location.abovebar, C_EXIT, size=size.small, text="EXIT CALL")
plotshape(showExitPut,  "EXIT PUT",  shape.xcross, location.belowbar, C_EXIT, size=size.small, text="EXIT PUT")

// ── BAR COLOUR ───────────────────────────────────────────────────────────────
bgcolor(i_show_bg and strongBUY  ? C_BGBUY : na, title="Strong BUY bar")
bgcolor(i_show_bg and strongSELL ? C_BGSEL : na, title="Strong SELL bar")
bgcolor(i_show_bg and daySideways and liveBar ? color.new(#888888, 93) : na, title="Sideways Warning")

// ── SIGNAL LINES — C and D time markers (alarm lines) ────────────────────────
if barstate.isconfirmed and liveBar
    if i_show_cd and atC
        line.new(bar_index, low*0.998, bar_index, high*1.002, color=C_G50, width=2, style=line.style_dashed)
    if i_show_cd and atD
        line.new(bar_index, low*0.999, bar_index, high*1.001, color=color.new(C_G50,40), width=1, style=line.style_dashed)
    if i_show_harm and (atCharm or atDharm)
        line.new(bar_index, low*0.999, bar_index, high*1.001, color=color.new(#F39C12,55), width=1, style=line.style_dashed)
    if i_show_harm and atCombo
        line.new(bar_index, low*0.999, bar_index, high*1.001, color=color.new(#F39C12,70), width=1, style=line.style_dotted)

// ── TABLE — 5 rows ────────────────────────────────────────────────────────────
var table tbl = table.new(
  i_tbl_pos=="Bottom Left"?position.bottom_left:i_tbl_pos=="Top Left"?position.top_left:i_tbl_pos=="Top Right"?position.top_right:position.bottom_right,
  3, 6,
  bgcolor=color.new(color.rgb(10,10,20),15),
  border_color=color.rgb(60,60,90), border_width=1,
  frame_color=color.rgb(60,60,90), frame_width=1)

tbl3(int r, string a, string b, string c2, color ca, color cb, color cc, color bg) =>
    table.cell(tbl, 0, r, a,  text_color=ca, bgcolor=bg, text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, r, b,  text_color=cb, bgcolor=bg, text_size=size.small, text_halign=text.align_center)
    table.cell(tbl, 2, r, c2, text_color=cc, bgcolor=bg, text_size=size.small, text_halign=text.align_right)

color G  = color.rgb(39,174,96)
color R  = color.rgb(192,57,43)
color GD = color.rgb(201,168,76)
color DM = color.rgb(140,130,110)
color CR = color.rgb(220,210,190)
color BG = color.new(color.rgb(10,10,20),10)
color HD = color.new(color.rgb(28,22,10),10)
color YL = color.rgb(232,200,109)

if i_show_table and barstate.islast
    // Row 0: Show trade status when in trade, otherwise signal/wait
    string tradeStatus = inTrade and isLong ? "IN CALL" : inTrade and not isLong ? "IN PUT" : ""
    string actNow = daySideways ? "SIDEWAYS" : dayWeak ? (strongBUY ? "STR BUY" : strongSELL ? "STR SELL" : sigBUY ? "BUY" : sigSELL ? "SELL" : showExitCall ? "EXIT CALL" : showExitPut ? "EXIT PUT" : inTrade ? tradeStatus : "WEAK") : strongBUY ? "STR BUY" : strongSELL ? "STR SELL" : sigBUY ? "BUY" : sigSELL ? "SELL" : showExitCall ? "EXIT CALL" : showExitPut ? "EXIT PUT" : inTrade ? tradeStatus : "WAIT"
    color actCol = (sigBUY or strongBUY) ? G : (sigSELL or strongSELL) ? R : (showExitCall or showExitPut) ? C_EXIT : inTrade and isLong ? G : inTrade and not isLong ? R : daySideways ? R : dayWeak ? YL : DM
    string adxStr = daySideways ? "SIDEWAYS" : dayWeak ? "WEAK" : emaUp ? "BULL" : "BEAR"
    color  adxCol = daySideways ? R : dayWeak ? YL : emaUp ? G : R
    table.cell(tbl, 0, 0, actNow, text_color=actCol, bgcolor=HD, text_size=size.large, text_halign=text.align_center)
    table.cell(tbl, 1, 0, adxStr + " " + str.tostring(math.round(adx,0)), text_color=adxCol, bgcolor=HD, text_size=size.small, text_halign=text.align_center)
    color scC = score>=75?G:score>=i_min_score?YL:R
    string scS = str.tostring(score) + (score>=75?" HI":score>=i_min_score?" OK":" LO")
    table.cell(tbl, 2, 0, scS, text_color=scC, bgcolor=HD, text_size=size.small, text_halign=text.align_right)

    // Row 1: C and D times
    string cStr = fC>0 ? "C:" + fmtT(tC) : "C:none"
    string dStr = "D:" + fmtT(tD)
    string barStr = atGann ? "NOW" : "WAIT"
    tbl3(1, cStr, dStr, barStr, GD, YL, atGann?GD:DM, BG)

    // Row 2: Direction votes + range + DIV status
    string dirStr = buyDir ? "BUY +" + str.tostring(absV) : sellDir ? "SELL +" + str.tostring(absV) : "TIE"
    color  dirCol = buyDir ? G : sellDir ? R : DM
    string rngStr = nearHigh ? "TOP PUT" : nearLow ? "BOT BUY" : str.tostring(math.round(rangePct*100,0)) + "%"
    color  rngCol = nearHigh ? R : nearLow ? G : YL
    string divStr = bullDiv and bearDiv ? "DIV BI" : bullDiv ? "DIV BUY" : bearDiv ? "DIV SELL" : "DIV --"
    string fvgStr = inBullFVG ? " FVG+" : inBearFVG ? " FVG-" : ""
    string lswStr = bullSweep ? " LSW+" : bearSweep ? " LSW-" : ""
    string smc    = divStr + fvgStr + lswStr
    color  smcCol = (bullDiv or inBullFVG or bullSweep) ? G : (bearDiv or inBearFVG or bearSweep) ? R : DM
    tbl3(2, dirStr, rngStr, smc, dirCol, rngCol, smcCol, BG)

    // Row 3: Entry / SL / Risk
    string eStr = not na(entPrice) ? "E:" + str.tostring(math.round(entPrice,1)) : "E:--"
    string sStr = not na(slLevel)  ? "SL:" + str.tostring(math.round(slLevel,1)) : "SL:--"
    string rStr = inTrade and not na(slLevel) and not na(entPrice) ? str.tostring(math.round(math.abs(entPrice-slLevel),0)) + "p" : "--"
    string hStr = inTrade ? str.tostring(holdBars) + "b" : "--"
    tbl3(3, eStr, sStr, rStr + " " + hStr, CR, inTrade?(isLong?G:R):DM, CR, BG)

    // Row 4: VWAP + Open + RSI
    string vwpStr = "V:" + (not na(vwapVal) ? str.tostring(math.round(vwapVal,0)) : "--")
    string oStr   = "O:" + str.tostring(_useW)
    string rsiStr = "RSI:" + str.tostring(math.round(rsi,0))
    tbl3(4, vwpStr, oStr, rsiStr, abvVWAP?G:R, DM, rsi>50?G:rsi<i_rsi_trap?R:DM, BG)

    // Row 5: OCB + blank + version
    string ocbStr = openBias==1 ? "BullO" : openBias==-1 ? "BearO" : "?"
    tbl3(5, ocbStr, "", "v19", openBias==1?G:R, DM, DM, BG)

// ── BACK TEST LOG ─────────────────────────────────────────────────────────────
var table btLog = table.new(position.top_left, 4, 12, bgcolor=color.rgb(10,10,20), border_color=color.rgb(60,60,90), border_width=1, frame_color=color.rgb(60,60,90), frame_width=1)
var array<string> bt_d = array.new<string>(10, "-")
var array<string> bt_s = array.new<string>(10, "-")
var array<string> bt_e = array.new<string>(10, "-")
var array<int>    bt_c = array.new<int>(10, 0)

if barstate.isconfirmed and (sigBUY or sigSELL)
    array.push(bt_d, str.format("{0,date,dd MMM}", time))
    array.push(bt_s, strongBUY ? "STR BUY" : strongSELL ? "STR SELL" : sigBUY ? "BUY" : "SELL")
    array.push(bt_e, str.tostring(math.round(close,1)))
    array.push(bt_c, score)
    if array.size(bt_d) > 10
        array.shift(bt_d)
        array.shift(bt_s)
        array.shift(bt_e)
        array.shift(bt_c)

if i_auto_open and barstate.islast
    table.cell(btLog, 0, 0, "DATE",  text_color=GD, bgcolor=HD, text_size=size.small)
    table.cell(btLog, 1, 0, "SIG",   text_color=GD, bgcolor=HD, text_size=size.small)
    table.cell(btLog, 2, 0, "ENTRY", text_color=GD, bgcolor=HD, text_size=size.small)
    table.cell(btLog, 3, 0, "SCORE", text_color=GD, bgcolor=HD, text_size=size.small)
    int sz = array.size(bt_d)
    for i = 0 to math.min(sz-1, 9)
        int sc = array.get(bt_c, i)
        string sg = array.get(bt_s, i)
        color scC2 = sc>=75 ? G : sc>=i_min_score ? YL : R
        color sgC2 = str.contains(sg,"BUY") ? G : R
        table.cell(btLog, 0, i+1, array.get(bt_d,i), text_color=CR, bgcolor=BG, text_size=size.small)
        table.cell(btLog, 1, i+1, sg,                text_color=sgC2, bgcolor=BG, text_size=size.small)
        table.cell(btLog, 2, i+1, array.get(bt_e,i), text_color=CR, bgcolor=BG, text_size=size.small)
        table.cell(btLog, 3, i+1, str.tostring(sc),  text_color=scC2, bgcolor=BG, text_size=size.small)

// ── ALERTS ───────────────────────────────────────────────────────────────────
alertcondition(strongBUY,                  "STRONG BUY",   "STRONG BUY. Score>=75. Enter CALL next bar. SL=bar low.")
alertcondition(strongSELL,                 "STRONG SELL",  "STRONG SELL. Score>=75. Enter PUT next bar. SL=bar high.")
alertcondition(sigBUY,                     "BUY Signal",   "BUY signal. Enter CALL next bar. SL=bar low.")
alertcondition(sigSELL,                    "SELL Signal",  "SELL signal. Enter PUT next bar. SL=bar high.")
alertcondition(showExitCall,               "EXIT CALL",    "STOP LOSS HIT. Exit your CALL option immediately.")
alertcondition(showExitPut,                "EXIT PUT",     "STOP LOSS HIT. Exit your PUT option immediately.")
alertcondition(strongBUY or strongSELL,    "STRONG Signal","Strong signal fired. Check chart direction.")
